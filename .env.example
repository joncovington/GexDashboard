# ─────────────────────────────────────────────────────────────
# Schwab API credentials
# Copy this file to .env and fill in your values.
# Get credentials from: https://developer.schwab.com
# ─────────────────────────────────────────────────────────────
SCHWAB_CLIENT_ID=your_client_id_here
SCHWAB_CLIENT_SECRET=your_client_secret_here
SCHWAB_REDIRECT_URI=https://127.0.0.1:8182

# Path to your Schwab OAuth token file.
# Run  python schwab_market.py --setup  once to generate it.
# Windows example:  C:/Users/your_username/Documents/.schwab_token.json
# Mac/Linux example: /home/your_username/.schwab_token.json
SCHWAB_TOKEN_PATH=/path/to/your/.schwab_token.json

# ─────────────────────────────────────────────────────────────
# Dashboard settings
# ─────────────────────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5556
